{
  "minimum-stability": "dev",
  "prefer-stable": true,
  "name": "fullstack-skeleton/craft",
  "description": "CraftCMS for Fullstack Skeleton",
  "type": "project",
  "require": {
    "craftcms/cms": "^5.8.0",
    "craftcms/ckeditor": "^4.9",
    "vlucas/phpdotenv": "^5.4.0"
  },
  "config": {
    "allow-plugins": {
      "craftcms/plugin-installer": true,
      "yiisoft/yii2-composer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.3"
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://composer.craftcms.com",
      "canonical": false
    }
  ]
}
